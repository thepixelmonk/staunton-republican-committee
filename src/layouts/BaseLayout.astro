---
import '@fontsource-variable/big-shoulders';
import '@fontsource-variable/hanken-grotesk';
import '../styles/global.css';
import '../styles/gothic/system.css';
import '../styles/gothic/hero.css';
import '../styles/gothic/modules.css';
import '../styles/gothic/engagement.css';

import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { site, url } from '../data/site';

interface Props {
  title?: string;
  description?: string;
  /** Error/utility pages: skip canonical + og:url and mark noindex. */
  noindex?: boolean;
}
const { title, description = site.description, noindex = false } = Astro.props;
const pageTitle = title ? `${title} — ${site.name}` : site.name;
const canonical = Astro.site ? new URL(Astro.url.pathname, Astro.site).href : Astro.url.pathname;
---

<!doctype html>
<html lang="en" data-theme="gothic">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    {
      noindex ? (
        <meta name="robots" content="noindex, nofollow" />
      ) : (
        <link rel="canonical" href={canonical} />
      )
    }
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#2c3e52" />
    <link rel="icon" type="image/svg+xml" href={url('favicon.svg')} />
    <link rel="icon" type="image/png" sizes="32x32" href={url('favicon-32.png')} />
    <link rel="apple-touch-icon" sizes="180x180" href={url('apple-touch-icon.png')} />

    <!-- Open Graph / social -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    {!noindex && <meta property="og:url" content={canonical} />}
    <meta name="twitter:card" content="summary" />
  </head>
  <body class="flex min-h-screen flex-col">
    <a
      href="#main"
      class="sr-only rounded-[2px] focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:bg-navy focus:px-4 focus:py-2 focus:font-body focus:text-sm focus:font-semibold focus:text-cream"
    >
      Skip to content
    </a>
    <Header />
    <main id="main" class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
