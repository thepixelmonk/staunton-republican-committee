---
import '@fontsource/zilla-slab/400.css';
import '@fontsource/zilla-slab/500.css';
import '@fontsource/zilla-slab/600.css';
import '@fontsource/zilla-slab/700.css';
import '@fontsource-variable/source-sans-3';
// Fonts for the alternate design directions (see ThemeSwitcher).
import '@fontsource-variable/big-shoulders';
import '@fontsource-variable/hanken-grotesk';
import '@fontsource-variable/fraunces';
import '@fontsource-variable/inter';
import '../styles/global.css';
// Structural overrides for the alternate design directions (loaded after
// global.css, unlayered, so they win over Tailwind utilities).
import '../styles/themes/gothic.css';
import '../styles/themes/capitol.css';

import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ThemeSwitcher from '../components/ThemeSwitcher.svelte';
import { site, url } from '../data/site';

interface Props {
  title?: string;
  description?: string;
  /** Error/utility pages: skip canonical + og:url and mark noindex. */
  noindex?: boolean;
}
const { title, description = site.description, noindex = false } = Astro.props;
const pageTitle = title ? `${title} — ${site.name}` : site.name;
const canonical = Astro.site ? new URL(Astro.url.pathname, Astro.site).href : Astro.url.pathname;
---

<!doctype html>
<html lang="en" data-theme="civic">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    {/* Apply the saved design direction before paint to avoid a flash. */}
    <script is:inline>
      (function () {
        try {
          var t = localStorage.getItem('src-theme');
          document.documentElement.dataset.theme = t || 'civic';
        } catch (e) {
          document.documentElement.dataset.theme = 'civic';
        }
      })();
    </script>
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    {
      noindex ? (
        <meta name="robots" content="noindex, nofollow" />
      ) : (
        <link rel="canonical" href={canonical} />
      )
    }
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#1f2a44" />
    <link rel="icon" type="image/svg+xml" href={url('favicon.svg')} />
    <link rel="icon" type="image/png" sizes="32x32" href={url('favicon-32.png')} />
    <link rel="apple-touch-icon" sizes="180x180" href={url('apple-touch-icon.png')} />

    <!-- Open Graph / social -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    {!noindex && <meta property="og:url" content={canonical} />}
    <meta name="twitter:card" content="summary" />
  </head>
  <body class="flex min-h-screen flex-col">
    <a
      href="#main"
      class="sr-only rounded-[2px] focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:bg-navy focus:px-4 focus:py-2 focus:font-body focus:text-sm focus:font-semibold focus:text-cream"
    >
      Skip to content
    </a>

    <!-- Demo: live design-direction selector (remove once a direction is chosen) -->
    <div class="border-b border-navy/15 bg-cream-deep print:hidden">
      <div
        class="mx-auto flex max-w-6xl flex-wrap items-center justify-center gap-x-4 gap-y-1.5 px-6 py-2 sm:justify-start"
      >
        <span class="font-body text-[0.7rem] font-semibold uppercase tracking-[0.16em] text-ink/60">
          Preview a design direction
        </span>
        <ThemeSwitcher client:load />
      </div>
    </div>

    <Header />
    <main id="main" class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
