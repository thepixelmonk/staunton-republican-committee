---
// Circular double-ring seal with a center star. Inherits color via currentColor.
interface Props {
  size?: number;
  class?: string;
  title?: string;
  /** When true, the seal is purely decorative (hidden from assistive tech). */
  decorative?: boolean;
}
const {
  size = 48,
  class: className = '',
  title = 'Staunton Republican Committee',
  decorative = false,
} = Astro.props;
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 100 100"
  width={size}
  height={size}
  class={className}
  role={decorative ? undefined : 'img'}
  aria-label={decorative ? undefined : title}
  aria-hidden={decorative ? 'true' : undefined}
  fill="none"
>
  <circle cx="50" cy="50" r="46" stroke="currentColor" stroke-width="2.5" />
  <circle cx="50" cy="50" r="39" stroke="currentColor" stroke-width="1.25" />
  <path
    fill="currentColor"
    d="M50 26 L55.58 42.31 L72.83 42.58 L59.04 52.94 L64.11 69.42 L50 59.5 L35.89 69.42 L40.96 52.94 L27.17 42.58 L44.42 42.31 Z"
  />
</svg>
