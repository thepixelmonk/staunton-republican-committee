---
// Small five-point star — the committee's recurring civic motif.
interface Props {
  size?: number;
  class?: string;
}
const { size = 16, class: className = '' } = Astro.props;
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 24 24"
  width={size}
  height={size}
  class={className}
  fill="currentColor"
  aria-hidden="true"
>
  <path d="M12 1.5 14.47 8.6 21.99 8.76 15.99 13.3 18.17 20.49 12 16.2 5.83 20.49 8.01 13.3 2.01 8.76 9.53 8.6Z" />
</svg>
