---
import { site } from '../data/site';
import Seal from './Seal.astro';
import SocialIcon from './SocialIcon.astro';
import Star from './Star.astro';

const year = new Date().getFullYear();
---

<footer class="site-footer bg-navy text-cream">
  <div class="mx-auto grid max-w-6xl gap-10 px-6 py-14 sm:grid-cols-2 lg:grid-cols-4">
    <!-- Brand -->
    <div class="sm:col-span-2 lg:col-span-1">
      <div class="flex items-center gap-3">
        <Seal size={42} class="text-gold" decorative />
        <span class="footer-wordmark text-xl">{site.name}</span>
      </div>
      <p class="footer-tagline mt-4 max-w-xs font-body text-sm leading-relaxed">
        {site.tagline}
      </p>
      {
        site.socials.length > 0 && (
          <div class="mt-5 flex gap-3">
            {site.socials.map((s) => (
              <a
                href={s.href}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={s.label}
                class="footer-social"
              >
                <SocialIcon icon={s.icon} size={18} />
              </a>
            ))}
          </div>
        )
      }
    </div>

    <!-- Explore -->
    <div>
      <h3 class="footer-col-head">Explore</h3>
      <ul class="space-y-2.5">
        {
          site.nav.map((item) => (
            <li>
              <a href={item.href} class="footer-link text-sm">
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    <!-- Contact -->
    <div>
      <h3 class="footer-col-head">Contact</h3>
      <ul class="space-y-2.5 font-body text-sm">
        <li>
          <a href={`mailto:${site.contact.email}`} class="footer-link">
            {site.contact.email}
          </a>
        </li>
        <li class="footer-link">{site.contact.phone}</li>
        <li class="footer-link">{site.contact.mailing}</li>
      </ul>
    </div>

    <!-- Meetings -->
    <div>
      <h3 class="footer-col-head">Meetings</h3>
      <ul class="space-y-2.5 font-body text-sm">
        <li class="footer-strong">{site.meeting.cadence}</li>
        <li class="footer-link">{site.meeting.when}</li>
        <li class="footer-link">{site.meeting.where}</li>
      </ul>
    </div>
  </div>

  <div class="footer-legal">
    <div
      class="mx-auto flex max-w-6xl flex-col gap-3 px-6 py-6 text-xs sm:flex-row sm:items-center sm:justify-between"
    >
      <p class="footer-legal-text flex items-center gap-2">
        <Star size={11} class="footer-star" />
        © {year} {site.name}. All rights reserved.
      </p>
      <p class="footer-legal-text max-w-md leading-relaxed sm:text-right">{site.disclaimer}</p>
    </div>
  </div>
</footer>
