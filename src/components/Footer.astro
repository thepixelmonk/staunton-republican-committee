---
import { site, url } from '../data/site';
import Seal from './Seal.astro';
import SocialIcon from './SocialIcon.astro';
import Star from './Star.astro';

const year = new Date().getFullYear();
---

<footer class="bg-navy text-cream">
  <div class="mx-auto grid max-w-6xl gap-10 px-6 py-14 sm:grid-cols-2 lg:grid-cols-4">
    <!-- Brand -->
    <div class="sm:col-span-2 lg:col-span-1">
      <div class="flex items-center gap-3">
        <Seal size={40} class="text-cream" decorative />
        <span class="font-display text-lg font-bold leading-tight">{site.name}</span>
      </div>
      <p class="mt-4 max-w-xs font-body text-sm leading-relaxed text-cream/70">
        {site.tagline}
      </p>
      {
        site.socials.length > 0 && (
          <div class="mt-5 flex gap-3">
            {site.socials.map((s) => (
              <a
                href={s.href}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={s.label}
                class="inline-flex h-9 w-9 items-center justify-center rounded-full border border-cream/25 text-cream/80 transition-colors hover:border-gold hover:text-gold"
              >
                <SocialIcon icon={s.icon} size={18} />
              </a>
            ))}
          </div>
        )
      }
    </div>

    <!-- Explore -->
    <div>
      <h3 class="font-body text-xs font-semibold uppercase tracking-[0.18em] text-gold">Explore</h3>
      <ul class="mt-4 space-y-2.5">
        {
          site.nav.map((item) => (
            <li>
              <a
                href={item.href}
                class="font-body text-sm text-cream/75 transition-colors hover:text-cream"
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    <!-- Contact -->
    <div>
      <h3 class="font-body text-xs font-semibold uppercase tracking-[0.18em] text-gold">Contact</h3>
      <ul class="mt-4 space-y-2.5 font-body text-sm text-cream/75">
        <li>
          <a href={`mailto:${site.contact.email}`} class="transition-colors hover:text-cream">
            {site.contact.email}
          </a>
        </li>
        <li>{site.contact.phone}</li>
        <li>{site.contact.mailing}</li>
      </ul>
    </div>

    <!-- Meetings -->
    <div>
      <h3 class="font-body text-xs font-semibold uppercase tracking-[0.18em] text-gold">Meetings</h3>
      <ul class="mt-4 space-y-2.5 font-body text-sm text-cream/75">
        <li class="font-semibold text-cream/90">{site.meeting.cadence}</li>
        <li>{site.meeting.when}</li>
        <li>{site.meeting.where}</li>
      </ul>
    </div>
  </div>

  <div class="border-t border-cream/15">
    <div
      class="mx-auto flex max-w-6xl flex-col gap-3 px-6 py-6 text-xs text-cream/55 sm:flex-row sm:items-center sm:justify-between"
    >
      <p class="flex items-center gap-2">
        <Star size={11} class="text-gold" />
        © {year} {site.name}. All rights reserved.
      </p>
      <p class="max-w-md leading-relaxed sm:text-right">{site.disclaimer}</p>
    </div>
  </div>
</footer>
