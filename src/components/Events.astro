---
import SectionHeading from './SectionHeading.astro';
import { events } from '../data/events';

const MONTHS = ['JAN', 'FEB', 'MAR', 'APR', 'MAY', 'JUN', 'JUL', 'AUG', 'SEP', 'OCT', 'NOV', 'DEC'];
const MONTHS_FULL = [
  'January', 'February', 'March', 'April', 'May', 'June',
  'July', 'August', 'September', 'October', 'November', 'December',
];

function fmtDate(iso: string) {
  const [, m, d] = iso.split('-').map(Number);
  return { mon: MONTHS[m - 1], day: String(d).padStart(2, '0'), full: `${MONTHS_FULL[m - 1]} ${d}` };
}
---

<section id="events" class="events py-20 sm:py-28">
  <div class="mx-auto max-w-6xl px-6">
    <SectionHeading eyebrow="Mark Your Calendar" title="Upcoming Events" />

    {
      events.length === 0 ? (
        <p class="events-empty mx-auto mt-12 max-w-md text-center font-body text-navy-deep/80">
          New events are being planned — check back soon.
        </p>
      ) : (
        <div class="event-list mx-auto mt-12 flex max-w-3xl flex-col gap-7">
          {events.map((event) => {
            const { mon, day, full } = fmtDate(event.date);
            return (
              <article class="event-card">
                <div class="event-date">
                  <span class="event-date-mon">{mon}</span>
                  <span class="event-date-day">{day}</span>
                  <span class="sr-only">{full}</span>
                </div>
                <div class="event-body-wrap">
                  <h3 class="event-title">{event.title}</h3>
                  <p class="event-meta">
                    {event.time} &middot; {event.location}
                  </p>
                  <p class="event-body">{event.description}</p>
                  {event.href && (
                    <a href={event.href} class="event-link">
                      Details
                    </a>
                  )}
                </div>
              </article>
            );
          })}
        </div>
      )
    }
  </div>
</section>
