---
// Reusable letterpress-style button. Renders an <a> when `href` is set,
// otherwise a <button>. Variants: solid (navy), ghost (outline), accent (brick).
interface Props {
  href?: string;
  variant?: 'solid' | 'ghost' | 'accent';
  size?: 'sm' | 'md';
  type?: 'button' | 'submit';
  class?: string;
}
const {
  href,
  variant = 'solid',
  size = 'md',
  type = 'button',
  class: className = '',
} = Astro.props;

const base =
  'inline-flex items-center justify-center gap-2 rounded-[2px] font-body font-semibold uppercase tracking-[0.08em] transition-colors duration-200 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brick';

const sizes = {
  sm: 'px-4 py-2 text-xs',
  md: 'px-6 py-3 text-sm',
};

const variants = {
  solid: 'bg-navy text-cream hover:bg-navy-deep',
  ghost: 'border border-navy/50 text-navy hover:bg-navy hover:text-cream',
  accent: 'bg-brick text-cream hover:bg-brick-strong',
};

const cls = `${base} ${sizes[size]} ${variants[variant]} ${className}`;
---

{
  href ? (
    <a href={href} class={cls}>
      <slot />
    </a>
  ) : (
    <button type={type} class={cls}>
      <slot />
    </button>
  )
}
