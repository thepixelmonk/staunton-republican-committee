---
import Star from './Star.astro';
import Button from './Button.astro';
import { site } from '../data/site';
---

<section id="get-involved" class="involve bg-navy py-20 sm:py-28">
  <div class="mx-auto max-w-6xl px-6">
    <div class="involve-heading text-center">
      <p class="involve-eyebrow mb-3 font-body text-xs font-semibold uppercase tracking-[0.18em] text-gold">
        Join Us
      </p>
      <h2 class="involve-title font-display text-3xl font-bold text-cream sm:text-4xl">Get Involved</h2>
      <div class="involve-rule mt-5 flex items-center justify-center gap-3">
        <span class="h-px w-10 bg-gold/60"></span>
        <Star size={14} class="text-gold" />
        <span class="h-px w-10 bg-gold/60"></span>
      </div>
    </div>

    <p class="involve-intro mx-auto mt-6 max-w-2xl text-center font-body text-lg leading-relaxed text-cream/80">
      There's a place for every neighbor here. Whether you have an hour or an evening,
      your time and voice help build a stronger Staunton.
    </p>

    <div class="involve-grid mt-14 grid gap-6 sm:grid-cols-3">
      {
        site.getInvolved.map((item) => (
          <div class="involve-card flex flex-col rounded-[2px] border border-cream/15 bg-cream/5 p-6">
            <h3 class="involve-card-title font-display text-xl font-semibold text-cream">{item.title}</h3>
            <p class="involve-body mt-2 flex-1 font-body text-sm leading-relaxed text-cream/75">{item.body}</p>
            <div class="mt-5">
              <Button href={item.cta.href} variant="accent" size="sm">
                {item.cta.label}
              </Button>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
