---
import { site, url } from '../data/site';
import Seal from './Seal.astro';
import Button from './Button.astro';
import MobileNav from './MobileNav.svelte';
---

<header class="site-header sticky top-0 z-40 border-b border-navy/15 bg-cream/90 backdrop-blur">
  <div class="mx-auto flex h-16 max-w-6xl items-center justify-between gap-4 px-6">
    <a href={url()} class="flex items-center gap-3 text-navy" aria-label={`${site.name} — home`}>
      <Seal size={36} class="shrink-0 text-navy" decorative />
      <span class="flex min-w-0 flex-col leading-tight">
        <span class="truncate font-display text-sm font-bold tracking-tight sm:text-lg">
          {site.name}
        </span>
        <span class="hidden font-body text-[0.65rem] uppercase tracking-[0.2em] text-stone sm:block">
          {site.city}
        </span>
      </span>
    </a>

    <nav class="hidden items-center gap-7 md:flex" aria-label="Primary">
      {
        site.nav.map((item) => (
          <a
            href={item.href}
            class="font-body text-sm font-semibold text-ink/80 transition-colors hover:text-brick"
          >
            {item.label}
          </a>
        ))
      }
      <Button href={site.primaryCta.href} size="sm">{site.primaryCta.label}</Button>
    </nav>

    <div class="md:hidden">
      <MobileNav client:load navItems={site.nav} cta={site.primaryCta} />
    </div>
  </div>
</header>
