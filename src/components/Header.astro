---
import { site, url } from '../data/site';
import Seal from './Seal.astro';
import Button from './Button.astro';
import MobileNav from './MobileNav.svelte';
---

<header class="site-header">
  <!-- flag-stripe accent caps the very top edge of the poster -->
  <span class="flag-stripe" aria-hidden="true"></span>

  <div class="site-header__bar">
    <a href={url()} class="masthead-lockup" aria-label={`${site.name} — home`}>
      <span class="masthead-seal" aria-hidden="true">
        <Seal size={30} decorative />
      </span>
      <span class="masthead-wordmark">
        <span class="masthead-name">{site.name}</span>
        <span class="masthead-city">{site.city}</span>
      </span>
    </a>

    <nav class="masthead-nav" aria-label="Primary">
      {site.nav.map((item) => <a href={item.href}>{item.label}</a>)}
      <Button href={site.primaryCta.href} size="sm">{site.primaryCta.label}</Button>
    </nav>

    <div class="masthead-mobile">
      <MobileNav client:load navItems={site.nav} cta={site.primaryCta} />
    </div>
  </div>
</header>
